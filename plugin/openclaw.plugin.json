{
  "id": "crystal-memory",
  "name": "Memory Crystal",
  "description": "Persistent memory for AI agents via Memory Crystal",
  "version": "0.1.0",
  "entry": "index.js",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "required": [],
    "properties": {
      "apiKey": {
        "type": "string"
      },
      "convexUrl": {
        "type": "string",
        "default": "https://rightful-mockingbird-389.convex.site"
      },
      "defaultRecallMode": {
        "type": "string",
        "enum": ["general", "decision", "project", "people", "workflow", "conversation"],
        "description": "Default recall mode for this agent. Controls which memory stores and categories are prioritized.",
        "default": "general"
      },
      "defaultRecallLimit": {
        "type": "number",
        "description": "Default number of memories to recall per query.",
        "default": 8,
        "minimum": 1,
        "maximum": 20
      }
    }
  }
}